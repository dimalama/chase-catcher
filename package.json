{
  "name": "chase-catcher",
  "version": "2.0.0",
  "description": "Chrome extension to automatically activate Chase credit card offers",
  "main": "src/js/background.ts",
  "scripts": {
    "build": "webpack --config config/webpack.config.js",
    "watch": "webpack --watch --config config/webpack.config.js",
    "test": "jest --config config/jest.config.js --ci --coverage --passWithNoTests",
    "test:watch": "jest --watch --config config/jest.config.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config config/.eslintrc.json src/",
    "lint:fix": "eslint --config config/.eslintrc.json src/ --fix",
    "format": "prettier --config config/.prettierrc --write src/",
    "format:check": "prettier --config config/.prettierrc --check src/",
    "clean": "rm -rf dist/ coverage/ package/",
    "package": "npm run clean && rm -f chase-catcher.zip && npm run build && mkdir -p package && cp manifest.json package/ && cp -r public package/ && cp -r dist package/ && cd package && zip -r ../chase-catcher.zip * && cd .. && echo 'Package created at chase-catcher.zip'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dimalama/chase-catcher"
  },
  "keywords": [
    "chrome-extension",
    "chase",
    "credit-card",
    "rewards",
    "automation"
  ],
  "author": "Dima Lukianenko",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/chrome": "^0.1.39",
    "@types/jest": "^30.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-jest": "^29.5.0",
    "babel-loader": "^9.1.2",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "prettier": "^2.8.8",
    "typescript": "^6.0.2",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
